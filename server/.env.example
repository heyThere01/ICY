# Database
MONGODB_URI=mongodb://localhost:27017/icy-influencer-db
NODE_ENV=development
PORT=5000

# JWT
JWT_SECRET=your-super-secret-jwt-key-here

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@icy-outreach.com

# YouTube Data API
YOUTUBE_API_KEY=your-youtube-api-key-here

# Instagram Basic Display API
INSTAGRAM_APP_ID=your-instagram-app-id-here
INSTAGRAM_APP_SECRET=your-instagram-app-secret-here

# Social Media APIs (for demo purposes)
SOCIAL_API_BASE_URL=https://api.socialmedia-demo.com
SOCIAL_API_KEY=your-social-api-key-here

# Client URL
CLIENT_URL=http://localhost:3000